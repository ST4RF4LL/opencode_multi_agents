{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "security-audit-orchestrator",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "external_directory": "allow",
    "todowrite": "deny",
    "bash": "ask",
    "task": "ask",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": {
      "*": "deny"
    },
    "context7_*": "deny",
    "gh_grep_*": "deny",
    "semgrep_*": "deny",
    "codeql_*": "deny",
    "joern_*": "deny",
    "cpp_index_*": "deny",
    "jvm_index_*": "deny",
    "python_index_*": "deny",
    "audit_lab_*": "deny"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "semgrep": {
      "enabled": false
    },
    "codeql": {
      "enabled": false
    },
    "joern": {
      "enabled": false
    },
    "cpp_index": {
      "enabled": false
    },
    "jvm_index": {
      "enabled": false
    },
    "python_index": {
      "enabled": false
    },
    "audit_lab": {
      "enabled": false
    }
  }
}
