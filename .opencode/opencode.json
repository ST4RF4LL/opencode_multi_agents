{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "security-audit-orchestrator",
  "permission": {
    "*": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "external_directory": "allow",
    "todowrite": "deny",
    "bash": "allow",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": {
      "*": "deny"
    },
    "context7_*": "deny",
    "gh_grep_*": "deny",
    "semgrep_*": "deny",
    "codeql_*": "deny",
    "joern_*": "allow",
    "cpp_index_*": "deny",
    "jvm_index_*": "deny",
    "python_index_*": "deny",
    "audit_lab_*": "deny",
    "vuln_judger_*": "deny",
    "vuln-judger_*": "deny"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "semgrep": {
      "enabled": false
    },
    "codeql": {
      "enabled": false
    },
    "joern": {
      "type": "local",
      "command": ["node", ".opencode/mcp/joern-server.mjs"],
      "cwd": ".",
      "environment": {
        "JOERN_BIN": "/usr/local/bin/joern",
        "JOERN_PARSE_BIN": "/usr/local/bin/joern-parse",
        "JOERN_VERSION": "4.0.579",
        "JOERN_GNUBIN": "/opt/homebrew/opt/coreutils/libexec/gnubin",
        "JOERN_JAVA_BIN": "/opt/homebrew/opt/openjdk@21/bin"
      },
      "timeout": 300000,
      "enabled": true
    },
    "cpp_index": {
      "enabled": false
    },
    "jvm_index": {
      "enabled": false
    },
    "python_index": {
      "enabled": false
    },
    "audit_lab": {
      "enabled": false
    },
    "vuln_judger": {
      "type": "local",
      "command": [
        "uv",
        "--directory",
        "$VULN_JUDGER_HOME",
        "run",
        "vuln-judger",
        "mcp",
        "--records-dir",
        "$VULN_JUDGER_HOME/.vuln-judger/runs",
        "--providers-file",
        "$VULN_JUDGER_HOME/.vuln-judger/providers.json",
        "--mcp-servers-file",
        "$VULN_JUDGER_HOME/.vuln-judger/mcp.json",
        "--skills-file",
        "$VULN_JUDGER_HOME/.vuln-judger/skills.json",
        "--agents-dir",
        "$VULN_JUDGER_HOME/agents"
      ],
      "enabled": true,
      "timeout": 120000
    }
  }
}
