{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "security-audit-orchestrator",
  "permission": {
    "*": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "external_directory": "allow",
    "todowrite": "deny",
    "bash": "allow",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": {
      "*": "deny"
    },
    "semgrep_*": "allow",
    "joern_*": "allow",
    "coverage_*": "allow",
    "cpp_index_*": "deny",
    "jvm_index_*": "deny",
    "python_index_*": "deny",
    "audit_lab_*": "deny",
    "vuln_judger_*": "deny",
    "vuln-judger_*": "deny"
  },
  "mcp": {
    "semgrep": {
      "type": "local",
      "command": ["node", ".opencode/mcp/semgrep-server.mjs"],
      "cwd": ".",
      "environment": {
        "OPENGREP_BIN": "opengrep",
        "SEMGREP_BIN": "semgrep",
        "SEMGREP_ENGINE": "auto"
      },
      "timeout": 900000,
      "enabled": true
    },
    "joern": {
      "type": "local",
      "command": ["node", ".opencode/mcp/joern-server.mjs"],
      "cwd": ".",
      "environment": {
        "JOERN_BIN": "/usr/local/bin/joern",
        "JOERN_PARSE_BIN": "/usr/local/bin/joern-parse",
        "JOERN_VERSION": "4.0.579",
        "JOERN_GNUBIN": "/opt/homebrew/opt/coreutils/libexec/gnubin",
        "JOERN_JAVA_BIN": "/opt/homebrew/opt/openjdk@21/bin"
      },
      "timeout": 300000,
      "enabled": true
    },
    "coverage_ledger": {
      "type": "local",
      "command": ["node", ".opencode/mcp/coverage-ledger-server.mjs"],
      "cwd": ".",
      "timeout": 300000,
      "enabled": true
    },
    "cpp_index": {
      "enabled": false
    },
    "jvm_index": {
      "enabled": false
    },
    "python_index": {
      "enabled": false
    },
    "audit_lab": {
      "enabled": false
    },
    "vuln_judger": {
      "enabled": false
    },
    "vuln-judger": {
      "enabled": false
    }
  }
}
